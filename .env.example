# Environment Configuration
# Copy this file to .env and fill in your values.
# Load with: python-dotenv or export manually before running.

# Flask environment: development | production | testing
FLASK_ENV=development

# The public-facing base URL (no trailing slash)
BASE_URL=http://localhost:5000

# Database URL
# SQLite (default):
DATABASE_URL=sqlite:///urls.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/urlshortener

# Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-long-random-secret

# Length of generated short codes (default 7 chars ~ 3.5 trillion combinations)
SHORT_CODE_LENGTH=7

# Default URL TTL in days (0 = no expiry)
DEFAULT_TTL_DAYS=0

# Max shortening requests per IP per minute (rate limiting)
RATE_LIMIT=10

# Cache TTL in seconds (300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Deduplicate: return same short code for duplicate long URLs
DEDUPLICATE_URLS=true
